# Local Postgres connection string — used if DATABASE_URL_AZURE is empty
DATABASE_URL=postgresql://calsight:calsight_dev@localhost:5433/calsight

# Shared Azure Postgres connection string. If set, overrides DATABASE_URL.
# The full .env with the Azure string is posted in Discord.
DATABASE_URL_AZURE=

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Set to false in production to disable debug mode and auto-docs
DEBUG=true
